generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model answers {
  roomCodeID     String
  username       String
  entered_answer String
  id             Int    @id
  games          games  @relation(fields: [roomCodeID], references: [roomCode], onDelete: NoAction, onUpdate: NoAction, map: "roomCodeID")

  @@unique([roomCodeID, entered_answer])
}

model games {
  roomCode String    @id
  letter   String    @db.Char
  topic    String
  answers  answers[]
}

model active_rooms {
  roomCodeID String @id
  username   String
}
